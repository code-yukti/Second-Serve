{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "second-serve/src/server/server.js"
    },
    {
      "src": "/health",
      "dest": "second-serve/src/server/server.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "second-serve/src/server/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "second-serve/src/server/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
