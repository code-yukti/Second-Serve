# Second Serve Environment Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Security - JWT Secret (Change this to a random secure string)
JWT_SECRET=your-super-secret-jwt-key-change-this-to-random-string

# Admin Dashboard Credentials
ADMIN_USERNAME=your-admin-username
ADMIN_SECRET_KEY=your-admin-secret-key

# Database Configuration (for PostgreSQL deployment - optional)
# DATABASE_URL=postgresql://username:password@localhost:5432/secondserve

# CORS Configuration (optional - for production)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
