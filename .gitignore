# Second Serve - .gitignore

# ==========================================
# ADMIN DASHBOARD - NEVER PUSH TO GITHUB
# ==========================================
ADMIN_DASHBOARD/
**/ADMIN_DASHBOARD/**
CREDENTIALS.md
PROJECT_SUMMARY.md

# Node modules
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# Database files
*.db
*.sqlite
*.sqlite3
database.db

# Environment files
.env
.env.local
.env.production
*.env

# Uploads
uploads/
**/uploads/**

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Build files
dist/
build/
*.min.js
*.min.css

# Test files
test/
tests/
*.test.js
coverage/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.cache

# Documentation (optional - remove if you want to push)
DATABASE_HACKATHON_GUIDE.pdf
DATABASE_HACKATHON_GUIDE.md

# Sensitive data
*secret*
*password*
*credentials*
